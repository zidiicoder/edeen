# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Fix for Swift pods and Firebase compatibility
use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'edeen' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Comprehensive Xcode 16.1 compatibility fixes
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Set minimum iOS deployment target to 13.0
        if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 13.0
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        end
        
        # Global warning suppression for Xcode 16.1
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['WARNING_CFLAGS'] = '-Wno-error'
        
        # CRITICAL: Disable explicit modules for ALL React Native targets in Release mode
        # This is the only way to fix ScanDependencies errors with Xcode 16.1 + RN 0.83.1
        if target.name.start_with?('React') || target.name.include?('react-native')
          config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
          config.build_settings['SWIFT_ENABLE_BARE_SLASH_REGEX'] = 'NO'
          # Disable module verifier which causes issues
          config.build_settings['CLANG_ENABLE_MODULE_VERIFIER'] = 'NO'
        end
        
        # Swift optimization issues in Release
        if config.name == 'Release'
          config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Osize'
        end
        
        # Enable module distribution for better compatibility
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
        
        # Use classic linker
        config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
        unless config.build_settings['OTHER_LDFLAGS'].include?('-Wl,-ld_classic')
          config.build_settings['OTHER_LDFLAGS'] << '-Wl,-ld_classic'
        end
        
        # Additional Xcode 16 compatibility flags
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end
    end
    
    # Fix script phases to include outputs (suppresses warnings)
    installer.pods_project.targets.each do |target|
      target.build_phases.each do |phase|
        if phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
          if phase.name&.include?('Hermes') || 
             phase.name&.include?('Bundle React Native') || 
             phase.name&.include?('RNFB')
            phase.always_out_of_date = '1'
          end
        end
      end
    end
    
    # Save the project to ensure changes are written
    installer.pods_project.save
  end
end
