# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Fix for Swift pods and Firebase compatibility
use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'edeen' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Fix deployment target warnings and C++ standard for all pods
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Set minimum iOS deployment target to 13.0
        if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 13.0
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        end
        
        # Fix C++ compilation issues
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
        
        # AGGRESSIVE FIX: Suppress all warnings
        config.build_settings['WARNING_CFLAGS'] = ['-w']
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        
        # Handle OTHER_CFLAGS (can be String or Array)
        if config.build_settings['OTHER_CFLAGS']
          if config.build_settings['OTHER_CFLAGS'].is_a?(Array)
            config.build_settings['OTHER_CFLAGS'] = config.build_settings['OTHER_CFLAGS'].map { |flag| flag.to_s.gsub(/-Wall|-Werror/, '') }.reject { |flag| flag.strip.empty? }
          elsif config.build_settings['OTHER_CFLAGS'].is_a?(String)
            config.build_settings['OTHER_CFLAGS'] = config.build_settings['OTHER_CFLAGS'].gsub(/-Wall|-Werror/, '').strip
          end
        else
          config.build_settings['OTHER_CFLAGS'] = ['$(inherited)']
        end
        
        # Handle OTHER_CPLUSPLUSFLAGS (can be String or Array)
        if config.build_settings['OTHER_CPLUSPLUSFLAGS']
          if config.build_settings['OTHER_CPLUSPLUSFLAGS'].is_a?(Array)
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = config.build_settings['OTHER_CPLUSPLUSFLAGS'].map { |flag| flag.to_s.gsub(/-Wall|-Werror/, '') }.reject { |flag| flag.strip.empty? }
          elsif config.build_settings['OTHER_CPLUSPLUSFLAGS'].is_a?(String)
            config.build_settings['OTHER_CPLUSPLUSFLAGS'] = config.build_settings['OTHER_CPLUSPLUSFLAGS'].gsub(/-Wall|-Werror/, '').strip
          end
        else
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = ['$(inherited)']
        end
        
        # Add -w to suppress all warnings for problematic targets
        if target.name == 'fmt' || target.name == 'glog' || target.name == 'Yoga'
          config.build_settings['OTHER_CFLAGS'] = ['$(inherited)', '-w'] unless config.build_settings['OTHER_CFLAGS'].is_a?(String) && config.build_settings['OTHER_CFLAGS'].include?('-w')
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = ['$(inherited)', '-w'] unless config.build_settings['OTHER_CPLUSPLUSFLAGS'].is_a?(String) && config.build_settings['OTHER_CPLUSPLUSFLAGS'].include?('-w')
        end
      end
    end
    
    # Modify the Pods Xcode project directly to remove warning flags
    installer.pods_project.build_configurations.each do |config|
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['WARNING_CFLAGS'] = ['-w']
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
    end
  end
end
