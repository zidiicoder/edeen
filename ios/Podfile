# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# NOTE: Do NOT enable `use_modular_headers!` globally. On React Native 0.80 it
# makes several React runtime pods (React-jsitooling, React-RuntimeApple,
# React-RCTRuntime) each emit a `react_runtime` modulemap into the same folder,
# which clang rejects as "Redefinition of module 'react_runtime'" and that
# poisons every downstream module. Instead, modular headers are enabled only on
# the Firebase/Google pods that actually need them (see inside the target).

# Build react-native-firebase as a static framework (needed when its Firebase
# dependencies are consumed as modules without global modular headers).
$RNFirebaseAsStaticFramework = true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'edeen' do
  config = use_native_modules!

  # Firebase + its dependencies require modular headers. Apply them ONLY to
  # these pods (not globally) so the React runtime pods are left alone.
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseMessaging', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'nanopb', :modular_headers => true
  pod 'PromisesObjC', :modular_headers => true

  # RN 0.83 runs on the New Architecture (Fabric + TurboModules).
  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # Xcode 16+ compatibility fixes
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Set minimum iOS deployment target
        config.build_settings.delete 'IPHONEOS_DEPLOYMENT_TARGET'

        # React Native 0.80 / fmt 11 require C++20. The standalone `fmt` pod
        # target otherwise inherits the compiler default and fails to compile
        # format.cc on CI (Xcode 16). Force the standard + libc++ for every pod.
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'

        # Suppress warnings
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['WARNING_CFLAGS'] = '-Wno-error'

        # Disable user script sandboxing for Xcode 16
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

        # Fix for RCTBridgeDelegate not found
        if target.name == 'React-RCTAppDelegate'
          config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
          config.build_settings['HEADER_SEARCH_PATHS'] << '$(PODS_ROOT)/Headers/Public/React-Core'
          config.build_settings['HEADER_SEARCH_PATHS'] << '$(PODS_ROOT)/Headers/Public/React-RCTAppDelegate'
        end
      end
    end
  end
end
