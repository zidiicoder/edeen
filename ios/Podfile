# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Fix for Swift pods and Firebase compatibility
use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'edeen' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Fix deployment target and compiler settings for all pods
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Set minimum iOS deployment target to 13.0
        if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 13.0
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        end
        
        # Global settings for all targets to handle Xcode 16 compatibility
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['WARNING_CFLAGS'] = '-Wno-error'
        
        # Disable modules for specific React core targets that have ScanDependencies issues in Xcode 16
        # Do NOT disable for third-party react-native-* libraries as they need modules for UIKit/WebKit
        react_core_targets = ['React-RuntimeHermes', 'React-RuntimeApple', 'React-RCTRuntime', 
                               'React-RCTAppDelegate', 'ReactCodegen', 'ReactCommon',
                               'React-Core', 'React-CoreModules', 'React-RCTAnimation',
                               'React-RCTBlob', 'React-RCTImage', 'React-RCTLinking',
                               'React-RCTNetwork', 'React-RCTSettings', 'React-RCTText',
                               'React-RCTVibration']
        
        if react_core_targets.include?(target.name)
          config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
        end
      end
    end
  end
end
