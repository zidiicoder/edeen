APP_NAME=Edeen
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://edeenapp.co.uk

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edeen
DB_USERNAME=edeen
DB_PASSWORD=

# --- Sanctum / API auth ---
# Token lifetime in minutes (null = never expires). 43200 = 30 days.
SANCTUM_TOKEN_EXPIRATION=43200

# --- Mail (used to deliver OTP codes) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-host.co.uk
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@edeenapp.co.uk"
MAIL_FROM_NAME="${APP_NAME}"

# --- Prayer times (Aladhan API) ---
# Calculation method id (2 = ISNA, 3 = MWL, 1 = University of Islamic Sciences, Karachi).
# Ahle Sunnat (Hanafi): method 1 (Karachi) + school 1 (Hanafi Asr).
PRAYER_TIMES_METHOD=1
# Asr juristic school: 0 = Shafi/standard, 1 = Hanafi.
PRAYER_TIMES_SCHOOL=1
# Hijri calendar for the Islamic date (MATHEMATICAL matches South-Asia/Pakistan).
PRAYER_HIJRI_METHOD=MATHEMATICAL

# --- Firebase Cloud Messaging (push notifications) ---
# Path (relative to base path) to the service-account JSON downloaded from
# Firebase Console -> Project settings -> Service accounts -> Generate new private key.
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=edeen-38edc

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database
